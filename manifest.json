{
  "manifest_version": 3,
  "name": "Archiver - 收藏同步助手",
  "version": "1.0.0",
  "description": "自动同步知乎收藏，支持 AI 摘要、分类标签和 Markdown/PDF/Word 导出",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://www.zhihu.com/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://dashscope.aliyuncs.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
